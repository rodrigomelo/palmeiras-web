{
  "name": "Palmeiras Agenda",
  "version": "1.1.53",
  "designSystemVersion": "3.0",
  "logo": {
    "source": "/static/brand/palmeiras-agenda-mark.svg",
    "lockup": "/static/brand/palmeiras-agenda-lockup.svg",
    "wordmark": "/static/brand/palmeiras-agenda-wordmark.svg",
    "small": "/static/brand/palmeiras-agenda-mark-small.svg",
    "rule": "Use the Campo marcado calendar-pitch mark for Palmeiras Agenda application identity; represent each team with its own club flag."
  },
  "colors": {
    "green950": "#043522",
    "green900": "#06412B",
    "green800": "#075C3B",
    "green700": "#0A7A4A",
    "green100": "#E7F1E9",
    "gold600": "#A97822",
    "gold500": "#C99A3D",
    "blue600": "#2468A8",
    "red600": "#B93B36",
    "violet600": "#8B3F68",
    "olive600": "#6B7F32",
    "ivory": "#FFFDF3",
    "mist": "#F3F5EF",
    "ink": "#10231A"
  },
  "typography": {
    "primary": "DM Sans",
    "fallback": "-apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    }
  },
  "radii": {
    "control": 6,
    "card": 8,
    "modal": 12,
    "brandMark": 18
  },
  "spacing": [4, 8, 12, 16, 24, 32, 48],
  "shadows": {
    "elevation1": "0 4px 14px rgba(4, 53, 34, 0.065)",
    "elevation2": "0 14px 32px rgba(4, 53, 34, 0.09)",
    "elevation3": "0 24px 64px rgba(4, 53, 34, 0.18)"
  },
  "motion": {
    "durationMs": 180,
    "easing": "cubic-bezier(0.2, 0.7, 0.2, 1)",
