  },
  "surfaces": {
    "header": {
      "gradient": ["#043522", "#064E31", "#113726"],
      "goldWashOpacity": 0.18,
      "gridStep": 68,
      "gridOpacity": 0.034
    },
    "hero": {
      "gradient": ["#064E31", "#0A6A42", "#10261C"],
      "goldWashOpacity": 0.12,
      "gridStep": 86,
      "gridOpacity": 0.029,
      "borderOpacity": 0.16
