    "icon192": "/static/brand/palmeiras-agenda-app-icon-192-v12.png",
    "icon512": "/static/brand/palmeiras-agenda-app-icon-512-v12.png",
    "maskable512": "/static/brand/palmeiras-agenda-maskable-512-v12.png",
