<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_competition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="PRÓXIMO JOGO"
            android:textColor="#C99A3D"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AO VIVO"
            android:textColor="#FF8078"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_match"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:text="Palmeiras × Adversário"
        android:textColor="#FFFDF3"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/widget_kickoff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Horário a confirmar"
        android:textColor="#B3C2B9"
        android:textSize="12sp" />
</LinearLayout>
